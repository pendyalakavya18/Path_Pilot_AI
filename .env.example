# Flask Configuration
FLASK_ENV=production
FLASK_SECRET_KEY=your-secret-key-here

# AI Configuration
# Set to 'true' to use fallback AI (no Ollama required)
USE_FALLBACK_AI=true

# Data Storage
# Use 'file' for local development, 'memory' for production
DATA_STORE_TYPE=memory

# Ollama Configuration (only needed if USE_FALLBACK_AI=false)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=tinyllama

# Backend URL (for frontend configuration)
# Replace this with your Render backend URL after deployment
BACKEND_URL=https://your-backend.onrender.com

